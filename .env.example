VITE_API_BASE_URL=http://localhost:4000

# Used for OTP-only login UI (email not shown on screen).
VITE_SUPERADMIN_EMAIL=alanjoshy@codeteak.com

# Optional: direct LAN scanner websocket endpoint (ws://ip:port/path).
# If unset, frontend uses backend Socket.IO feed.
VITE_SCANNER_WS_URL=

# Frontend Go-UPC token (exposed in browser build; rotate often and keep low quota).
VITE_GO_UPC_API_TOKEN=
VITE_GO_UPC_TIMEOUT_MS=8000

